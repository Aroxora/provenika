# Copy to outreach/.env (gitignored) and fill in. NEVER commit real secrets.
# In the cloud use AWS Secrets Manager / SSM (Lambda) or GitHub Actions secrets.

# --- LLM provider (switch with LLM_PROVIDER) ---
# deepseek -> OpenAI + Anthropic formats (auto-switch) | xai -> Grok (grok-4.3)
# openai | anthropic. Per-provider keys; any field overridable via LLM_* below.
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
XAI_API_KEY=xai-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_API_KEY=...   ANTHROPIC_API_KEY=...
# Overrides: LLM_API_KEY  LLM_BASE_URL  LLM_ANTHROPIC_BASE_URL  LLM_FORMAT(openai|anthropic|auto)  LLM_MODEL
# Or save at runtime (gitignored): python3 outreach/cli.py keys --llm-key ... --llm-model grok-4.3
GOOGLE_APPLICATION_CREDENTIALS=outreach/.state/service-account.json   # Firebase Admin (gitignored)
NOTIFY_EMAIL=you@example.com   # operational update emails go here

# --- Tavily (prospect research) ---
TAVILY_API_KEY=tvly-dev-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Email via Proton Bridge (runs locally; self-signed cert) ---
# Verified against Proton Bridge: IMAP 1143 = STARTTLS, SMTP 1025 = implicit SSL.
IMAP_HOST=127.0.0.1
IMAP_PORT=1143
IMAP_USER=you@pm.me
IMAP_PASS=bridge-password
IMAP_SECURITY=STARTTLS

SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_USER=you@pm.me
SMTP_PASS=bridge-password
SMTP_SECURITY=SSL          # Proton Bridge uses implicit SSL on 1025 (not STARTTLS)

FROM_NAME=Your Name
FROM_EMAIL=you@pm.me
REPLY_TO=you@pm.me              # use the MONITORED mailbox so replies get an agentic response
HUMAN_NAME=Your Name
HUMAN_EMAIL=you@example.com     # disclosed in every email for direct human contact
HUMAN_EMAIL_ALT=you@alt.org    # optional second address
HUMAN_PHONE=+1 555-555-5555     # optional phone, disclosed in the footer

# Agentic auto-reply (also requires SEND_ENABLED=true). Off = drafts replies for review.
AUTO_REPLY_ENABLED=false
MAX_AUTO_REPLIES_PER_CONTACT=3
MONITOR_POLL_SECONDS=30
MONITOR_USE_IDLE=true

# --- Store backend: local (default) or firestore ---
STORE_BACKEND=local
LOCAL_STORE_PATH=outreach/.state/store.json
GOOGLE_CLOUD_PROJECT=
FIRESTORE_COLLECTION=outreach

# --- Safety rails ---
SEND_ENABLED=false          # DRY-RUN by default; flip to true only after review
DAILY_SEND_CAP=20
MIN_HOURS_BETWEEN_TOUCHES=72
